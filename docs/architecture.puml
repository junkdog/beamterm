@startuml architecture

' ============================================================================
' GRUVBOX DARK THEME
' ============================================================================

skinparam backgroundColor #282828
skinparam defaultFontColor #ebdbb2
skinparam defaultFontName monospace
skinparam roundcorner 8
skinparam shadowing false
skinparam linetype polyline
skinparam nodesep 4
skinparam ranksep 10

skinparam note {
  BackgroundColor #3c3836
  BorderColor #504945
  FontColor #d5c4a1
}

skinparam arrow {
  Color #83a598
  FontColor #a89984
}

skinparam package {
  BackgroundColor #32302f
  BorderColor #83a598
  FontColor #fabd2f
  StereotypeFontColor #8ec07c
}

skinparam rectangle {
  BackgroundColor #3c3836
  BorderColor #504945
  FontColor #ebdbb2
}

skinparam component {
  BackgroundColor #32302f
  BorderColor #83a598
  FontColor #fabd2f
  StereotypeFontColor #8ec07c
  BorderThickness 2
}

' ============================================================================
' TITLE
' ============================================================================

title <font color="#fabd2f" size="22">beamterm Architecture</font>\n<font color="#d5c4a1" size="14">GPU-Accelerated Terminal Renderer</font>

' ============================================================================
' EXTERNAL SYSTEMS (top)
' ============================================================================

[<color:#fe8019><b>Browser</b></color>\nCanvas, WebGL2, DOM] as browser
[<color:#fe8019><b>Native Examples</b></color>\nglutin + winit, OpenGL 3.3\nnative-terminal, terminal-emulator\ngame-console] as native
[<color:#fe8019><b>NPM Package</b></color>\n@beamterm renderer] as npm

' ============================================================================
' CRATES
' ============================================================================

package "beamterm-renderer" <<WASM Integration>> {
  [Terminal Builder\nterminal.rs] as builder
  [WASM Bindings\nwasm.rs] as wasm
  [CanvasRasterizer\nCanvas API rasterizer] as canvas_rast
}

note right of canvas_rast
  <color:#8ec07c>Mouse Selection</color> | <color:#8ec07c>HiDPI</color> | <color:#8ec07c>Context Loss</color>
end note

package "beamterm-core" <<GL Engine>> {
  together {
    [TerminalGrid\nGPU buffers, VAO] as grid
    [StaticFontAtlas\npre-built atlas] as static_atlas
    [DynamicFontAtlas<R>\ngeneric, LRU cache] as dynamic_atlas
    [SelectionTracker\nBlock/Linear modes] as sel_tracker
    [CellQuery\nzero-alloc text extraction] as cell_query
  }
  together {
    [GlyphRasterizer trait\nplatform abstraction] as rast_trait
    [Shaders\ncell.vert, cell.frag] as shaders
    [Drawable\nRenderContext] as drawable
    [GlState\nGL deduplication] as glstate
    [DirtyRegions\npartial GPU uploads] as dirty
    [glow\nOpenGL 3.3 + WebGL2] as glow
  }

  note as core_note
    <color:#fabd2f><b>Rendering Pipeline</b></color>
    <color:#8ec07c>6 buffers</color> → <color:#d3869b>1 instanced draw call</color>
    <color:#8ec07c>Es300</color> (WebGL2) | <color:#8ec07c>Gl330</color> (OpenGL 3.3)
    ....
    <color:#fb4934>*</color> ASCII fast path <color:#fb4934>*</color> 8B packed cells
    <color:#fb4934>*</color> LRU glyph cache <color:#fb4934>*</color> partial upload
  end note

  grid .. core_note
}

package "beamterm-data" <<Shared>> {
  [FontAtlasData\nversioned binary] as atlas_data
  [Glyph Encoding\n16-bit packed IDs] as glyph_enc
}

package "beamterm-atlas" <<Generator>> {
  [Atlas CLI\nTTF to .atlas] as atlas_cli
  [Texture Arrays\n32 glyphs per layer] as tex_arrays
}

package "beamterm-rasterizer" <<Native Rasterizer>> {
  [NativeRasterizer\nswash + fontdb] as native_rast
  [FontResolver\nfallback chain] as font_resolver
  [CellMetrics\ncell size + scaling] as cell_metrics
}

' ============================================================================
' NOTES (floating, linked to fill dead space)
' ============================================================================

' notes moved inside beamterm-core (see package block above)

' ============================================================================
' RELATIONSHIPS
' ============================================================================

browser --> builder : <color:#fe8019>WebGL2</color>
npm --> wasm : <color:#fe8019>JS API</color>
native --> grid : <color:#fe8019>OpenGL 3.3</color>

builder --> grid : <color:#b8bb26>uses</color>
wasm --> builder
canvas_rast ..|> rast_trait : <color:#b8bb26>implements</color>

grid --> glstate : <color:#a89984>min GL calls</color>
grid --> shaders
grid --> drawable
grid --> glow
grid --> dirty : <color:#a89984>partial uploads</color>

dynamic_atlas --> rast_trait : <color:#b8bb26>uses</color>
static_atlas ..[#83a598].. dynamic_atlas : <color:#a89984>both implement\n<color:#a89984>sealed Atlas trait</color>

grid --> atlas_data : <color:#b8bb26>reads</color>
atlas_cli --> atlas_data : <color:#b8bb26>writes</color>

rast_trait <|.. native_rast : <color:#b8bb26>implements\n<color:#a89984>(native-dynamic-atlas)</color>
native_rast --> font_resolver

' layout hints
glow -[hidden]right-> dirty
shaders -[hidden]right-> drawable
rast_trait -[hidden]right-> shaders
atlas_data -[hidden]right-> glyph_enc
atlas_cli -[hidden]right-> tex_arrays
cell_query -[hidden]right-> native_rast

@enduml
